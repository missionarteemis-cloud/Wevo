rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isChatParticipant(chatId) {
      return signedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.users;
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if isSelf(userId);
      allow update: if isSelf(userId);
      allow delete: if false;
    }

    match /swipes/{swipeId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.from == request.auth.uid
        && request.resource.data.to is string
        && request.resource.data.liked is bool;
      allow update, delete: if false;
    }

    match /matches/{matchId} {
      allow read: if signedIn() && request.auth.uid in resource.data.users;
      allow create: if signedIn()
        && request.auth.uid in request.resource.data.users
        && request.resource.data.users.size() == 2;
      allow update: if signedIn() && request.auth.uid in resource.data.users;
      allow delete: if false;
    }

    match /chats/{chatId} {
      allow read: if signedIn() && request.auth.uid in resource.data.users;
      allow create: if signedIn()
        && request.auth.uid in request.resource.data.users
        && request.resource.data.users.size() == 2;
      allow update: if signedIn() && request.auth.uid in resource.data.users;
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isChatParticipant(chatId);
        allow create: if isChatParticipant(chatId)
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.text is string;
        allow update, delete: if false;
      }
    }
  }
}
