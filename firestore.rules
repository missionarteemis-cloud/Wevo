rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isChatParticipant(chatId) {
      return signedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.users;
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if isSelf(userId)
        && !('coins' in request.resource.data)
        && !('inventory' in request.resource.data);
      allow update: if isSelf(userId)
        && request.resource.data.coins == resource.data.coins;
      allow delete: if false;

      match /inventory/{instanceId} {
        allow read: if isSelf(userId);
        allow write: if false;
      }
    }

    match /rooms/{ownerUid} {
      allow read: if signedIn();
      allow create, update: if signedIn()
        && request.auth.uid == ownerUid
        && request.resource.data.ownerUid == ownerUid;
      allow delete: if false;
    }

    match /catalog/{itemId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /swipes/{swipeId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.from == request.auth.uid
        && request.resource.data.to is string
        && request.resource.data.liked is bool;
      allow update, delete: if false;
    }

    match /matches/{matchId} {
      allow read: if signedIn() && request.auth.uid in resource.data.users;
      allow create: if signedIn()
        && request.auth.uid in request.resource.data.users
        && request.resource.data.users.size() == 2
        && request.resource.data.users[0] != request.resource.data.users[1];
      allow update: if false;
      allow delete: if false;
    }

    match /chats/{chatId} {
      allow read: if signedIn() && request.auth.uid in resource.data.users;
      allow create, update: if false;
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isChatParticipant(chatId);
        allow create, update, delete: if false;
      }

      match /reads/{readerUid} {
        allow read: if isChatParticipant(chatId);
        allow create, update: if isChatParticipant(chatId)
          && request.auth.uid == readerUid
          && request.resource.data.uid == readerUid
          && request.resource.data.lastReadAt is timestamp;
        allow delete: if false;
      }
    }
  }
}
